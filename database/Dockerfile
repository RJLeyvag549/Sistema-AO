FROM influxdb:2.7

# Configuraciones iniciales (puedes personalizarlas aquí si quieres)
# InfluxDB usa estas variables para el setup inicial
ENV DOCKER_INFLUXDB_INIT_MODE=setup
ENV DOCKER_INFLUXDB_INIT_USERNAME=admin
ENV DOCKER_INFLUXDB_INIT_PASSWORD=password123
ENV DOCKER_INFLUXDB_INIT_ORG=ao_org
ENV DOCKER_INFLUXDB_INIT_BUCKET=ao_telemetry

EXPOSE 8086
